{
    "name": "@geysermc/actions-upload-release",
    "private": true,
    "version": "1.0.0",
    "description": "An action to upload releases via SCP",
    "author": "GeyserMC",
    "license": "AGPL-3.0-only",
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "package": "esbuild index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --external:*.node --legal-comments=external",
        "package:watch": "npm run package -- --watch"
    },
    "dependencies": {
        "@actions/core": "3.0.1",
        "node-scp": "0.0.25",
        "tslib": "2.6.2"
    },
    "devDependencies": {
        "@geysermc/actions-release": "1.0.0"
    }
}
