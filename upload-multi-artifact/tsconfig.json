{
    "$schema": "https://json.schemastore.org/tsconfig",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "rootDir": "./",
        "moduleResolution": "NodeNext",
        "types": [
            "node"
        ],
        "sourceMap": true,
        "outDir": "./dist",
        "noImplicitAny": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "newLine": "lf"
    },
    "include": [
        "*.ts"
    ]
}