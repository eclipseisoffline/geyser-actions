{
    "name": "@geysermc/actions-upload-multi-artifact",
    "private": true,
    "version": "1.0.0",
    "description": "An action to upload multiple action artifacts",
    "author": "GeyserMC",
    "license": "AGPL-3.0-only",
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "package": "esbuild index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --external:*.node --legal-comments=external --banner:js=\"const import_meta_url = require('url').pathToFileURL(__filename).href;\" --define:import.meta.url=import_meta_url",
        "package:watch": "npm run package -- --watch"
    },
    "dependencies": {
        "@actions/artifact": "6.2.1",
        "@actions/core": "3.0.1",
        "glob": "13.0.6",
        "tslib": "2.6.2"
    }
}
