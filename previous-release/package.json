{
    "name": "@geysermc/actions-previous-release",
    "private": true,
    "version": "1.0.0",
    "description": "An action to get outputs for the previous release",
    "author": "GeyserMC",
    "license": "AGPL-3.0-only",
    "exports": {
        ".": "./dist/index.js"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "package": "esbuild index.ts --bundle --platform=node --target=node24 --outfile=dist/index.js --external:*.node --legal-comments=external",
        "package:watch": "npm run package -- --watch"
    },
    "dependencies": {
        "@actions/core": "3.0.1",
        "@octokit/auth-app": "8.2.0",
        "@octokit/core": "7.0.6",
        "@octokit/plugin-rest-endpoint-methods": "17.0.0",
        "tslib": "2.6.2"
    }
}
